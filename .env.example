# MongoDB connection
MONGODB_URI=Mongodb+srv://your-username:
MONGODB_DB_NAME=Mongodb-database-name

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=your-preferred-openai-model

# Admin authentication (generate a random key: python -c "import secrets; print(secrets.token_urlsafe(32))")
ADMIN_API_KEY=your-admin-key-here

# Application
APP_ENV=development
APP_PORT=8000

# Google OAuth (get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Session
SESSION_SECRET_KEY=change-me-generate-with-python-secrets
SESSION_MAX_AGE=86400

# Rate limiting (share endpoint)
RATE_LIMIT_MAX_REQUESTS=3
RATE_LIMIT_WINDOW_SECONDS=600
